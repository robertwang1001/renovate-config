{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>robertwang1001/renovate-config",
    "security:minimumReleaseAgeNpm",
    "helpers:disableTypesNodeMajor"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "node"
      ],
      "enabled": false
    },
    {
      "matchDepTypes": [
        "peerDependencies"
      ],
      "enabled": false
    }
  ]
}
