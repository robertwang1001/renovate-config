{
  "name": "renovate-config",
  "type": "module",
  "version": "1.2.1",
  "description": "Shared Renovate Configurations",
  "author": {
    "name": "Robert Wang",
    "email": "glorywong1001@gmail.com",
    "url": "https://glorywong.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/robertwang1001/renovate-config#readme",
  "repository": "github:robertwang1001/renovate-config",
  "bugs": "https://github.com/robertwang1001/renovate-config/issues",
  "keywords": [],
  "scripts": {
    "test": "renovate-config-validator --no-global renovate.json default.json npm.json deno.json",
    "prepare": "pnpm simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "eslint": "^10.3.0",
    "lint-staged": "^17.0.4",
    "renovate": "^43.150.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit ${1}",
    "pre-commit": "pnpm lint-staged && pnpm test"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  }
}
